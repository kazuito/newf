{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: watch",
      "type": "shell",
      "command": "pnpm",
      "args": ["watch"],
      "problemMatcher": [
        {
          "owner": "rolldown",
          "pattern": {
            "regexp": "^(?!x)x"
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^> newf@.+ watch .*$",
            "endsPattern": "^✔ Rebuilt .*$"
          }
        }
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
