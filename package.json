{
	"name": "newf",
	"displayName": "newf",
	"description": "Create new files/folders quickly.",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.110.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "newf.create",
				"title": "Create New File",
				"category": "Newf"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm run compile && pnpm run lint",
		"lint": "biome check",
		"format": "biome format --write",
		"check": "biome check --write",
		"test": "vscode-test",
		"typecheck": "tsc --noEmit",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/vscode": "^1.110.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"husky": "^9.1.7",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"brace-expansion": "^5.0.4"
	}
}
