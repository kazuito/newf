{
  "name": "newf",
  "displayName": "Newf",
  "description": "Create new files and folders from the command palette with brace expansion and templates.",
  "version": "0.0.4",
  "publisher": "kazuito",
  "license": "MIT",
  "icon": "./icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kazuito/newf"
  },
  "bugs": {
    "url": "https://github.com/kazuito/newf/issues"
  },
  "keywords": [
    "file",
    "folder",
    "new file",
    "new folder",
    "create file",
    "create folder",
    "template",
    "brace expansion",
    "command palette"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "scripts": {
    "vscode:prepublish": "pnpm run bundle",
    "bundle": "rolldown -c",
    "compile:tests": "tsc -p ./tsconfig.test.json",
    "compile": "pnpm run bundle && pnpm run compile:tests",
    "watch": "rolldown -c -w",
    "watch:tests": "tsc -watch -p ./tsconfig.test.json",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "vscode-test",
    "typecheck": "tsc --noEmit",
    "check": "pnpm biome check --write && pnpm test",
    "package": "vsce package --no-dependencies",
    "pretest": "pnpm run compile",
    "prepare": "husky"
  },
  "contributes": {
    "commands": [
      {
        "command": "newf.newFile",
        "title": "%command.newFile.title%",
        "category": "Newf"
      },
      {
        "command": "newf.newFileAtRoot",
        "title": "%command.newFileAtRoot.title%",
        "category": "Newf"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "newf.newFile",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "newf.newFile",
          "when": "!explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Newf",
      "properties": {
        "newf.templates": {
          "type": "object",
          "scope": "resource",
          "default": {},
          "description": "%config.templates.description%",
          "additionalProperties": {
            "type": "string"
          }
        },
        "newf.respectGitignore": {
          "type": "boolean",
          "default": true,
          "description": "%config.respectGitignore.description%"
        },
        "newf.notifyOnCreate": {
          "type": "boolean",
          "default": true,
          "description": "%config.notifyOnCreate.description%"
        },
        "newf.openAfterCreate": {
          "type": "string",
          "enum": [
            "last",
            "all",
            "none"
          ],
          "enumDescriptions": [
            "%config.openAfterCreate.last%",
            "%config.openAfterCreate.all%",
            "%config.openAfterCreate.none%"
          ],
          "default": "last",
          "description": "%config.openAfterCreate.description%"
        }
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "brace-expansion": "^5.0.4",
    "husky": "^9.1.7",
    "ignore": "^7.0.5",
    "rolldown": "1.0.0-rc.9",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
