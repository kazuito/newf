{
	"name": "newf",
	"displayName": "Newf",
	"description": "Create new files and folders from the command palette. Fast, with brace expansion.",
	"version": "0.0.1",
	"publisher": "kazuito",
	"license": "MIT",
	"icon": "./icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/kazuito/newf"
	},
	"bugs": {
		"url": "https://github.com/kazuito/newf/issues"
	},
	"keywords": [
		"file",
		"new file",
		"create file",
		"brace expansion",
		"command palette"
	],
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "newf.newFile",
				"title": "Create New File",
				"category": "Newf"
			},
			{
				"command": "newf.newFileAtRoot",
				"title": "Create New File at Path",
				"category": "Newf"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "newf.newFile",
					"when": "explorerResourceIsFolder",
					"group": "navigation"
				},
				{
					"command": "newf.newFile",
					"when": "!explorerResourceIsFolder",
					"group": "navigation"
				}
			]
		},
		"configuration": {
			"title": "Newf",
			"properties": {
				"newf.openAfterCreate": {
					"type": "string",
					"enum": ["last", "all", "none"],
					"enumDescriptions": [
						"Open the last created file",
						"Open all created files",
						"Do not open any files"
					],
					"default": "last",
					"description": "Which files to open in the editor after creation."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm run compile && pnpm run lint",
		"lint": "biome check",
		"format": "biome format --write",
		"check": "biome check --write",
		"test": "vscode-test",
		"typecheck": "tsc --noEmit",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/vscode": "^1.100.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"husky": "^9.1.7",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"brace-expansion": "^5.0.4"
	}
}
